+/* ─── Accessibility: Reduced Motion ──────────────────────────────────────────
+   Respects the OS "Reduce Motion" accessibility setting (WCAG 2.1 §2.3.3).
+   Collapses all animation/transition durations to a single frame so content
+   still appears (opacity changes) but no movement or looping occurs.
+   Covers Tailwind utilities (animate-spin, animate-pulse, animate-shimmer, etc.)
+   as well as all custom keyframes defined above.
+─────────────────────────────────────────────────────────────────────────────── */
+@media (prefers-reduced-motion: reduce) {
+	*,
+	*::before,
+	*::after {
+		animation-duration: 0.01ms !important;
+		animation-iteration-count: 1 !important;
+		transition-duration: 0.01ms !important;
+		scroll-behavior: auto !important;
+	}
+}
