diff --git a/webview-ui/src/components/chat/task-header/ContextWindowRing.tsx b/webview-ui/src/components/chat/task-header/ContextWindowRing.tsx
new file mode 100644
index 000000000..1a584fe4a
--- /dev/null
+++ b/webview-ui/src/components/chat/task-header/ContextWindowRing.tsx
@@ -0,0 +1,47 @@
+import type React from "react"
+import { memo } from "react"
+import { cn } from "@/lib/utils"
+
+interface ContextWindowRingProps {
+	percentage: number
+	className?: string
+}
+
+const ContextWindowRing: React.FC<ContextWindowRingProps> = ({ percentage, className }) => {
+	const clamped = Math.max(0, Math.min(100, percentage))
+	const radius = 7
+	const circumference = 2 * Math.PI * radius
+	const strokeDashoffset = circumference - (clamped / 100) * circumference
+
+	const progressColor = clamped >= 90 ? "text-error" : clamped >= 70 ? "text-warning" : "text-success"
+
+	return (
+		<span className={cn("inline-flex h-4 w-4 shrink-0", className)}>
+			<svg aria-hidden="true" className="h-4 w-4 -rotate-90" viewBox="0 0 20 20">
+				<circle
+					className="text-muted-foreground/25"
+					cx="10"
+					cy="10"
+					fill="none"
+					r={radius}
+					stroke="currentColor"
+					strokeWidth="2"
+				/>
+				<circle
+					className={cn("transition-all duration-200", progressColor)}
+					cx="10"
+					cy="10"
+					fill="none"
+					r={radius}
+					stroke="currentColor"
+					strokeDasharray={circumference}
+					strokeDashoffset={strokeDashoffset}
+					strokeLinecap="round"
+					strokeWidth="2"
+				/>
+			</svg>
+		</span>
+	)
+}
+
+export default memo(ContextWindowRing)
